# PRIMARY LLM — Groq (free, get key at groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# VISION / SCANNED DOCS — Gemini (free, get key at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# VECTOR DB — Qdrant local (free, no key needed)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# DATABASE
DATABASE_URL=sqlite:///./tender_eval.db

# THRESHOLDS
OCR_CONFIDENCE_THRESHOLD=0.80
SEMANTIC_SIMILARITY_PASS_THRESHOLD=0.75
SEMANTIC_SIMILARITY_REVIEW_THRESHOLD=0.50
